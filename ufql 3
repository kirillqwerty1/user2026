настройка sshuser

useradd <имя пользователя> или useradd -u <id> <имя пользователя> с нужным id
echo "<имя пользователя>:P@ssw0rd" | chpasswd
usermod -aG wheel <имя пользователя>
echo "WHEEL_USERS ALL=(ALL:ALL) NOPASSWD: ALL" > /etc/sudoers.d/<имя пользователя>
su -l <имя пользователя>
sudo id
