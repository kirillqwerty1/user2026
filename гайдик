cat <<EOF> /etc/nftables/nftables.nft
#!/usr/sbin/nft -f
flush ruleset
table ip nat {
 chain postrouting {
 type nat hook postrouting priority arcnat;
 oifname "enp7s1" masquerade
 }
}
systemctl enable --now nftables
vim /etc/net/sysctl.conf  >  net.ipv4.ip_forward = 1
systemctl restart network
